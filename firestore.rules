rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSafeInt(value) {
      return value is int
          && value >= -9007199254740991
          && value <= 9007199254740991;
    }

    function isPositiveSafeInt(value) {
      return isSafeInt(value) && value > 0;
    }

    function isIsoDate(value) {
      return value is string && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isStringSized(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function txAllowedKeys() {
      return [
        'description', 'value_cents', 'schemaVersion', 'type', 'category',
        'date', 'source', 'account', 'accountId', 'cardId', 'fitId', 'tags',
        'isRecurring', 'importHash', 'createdAt', 'updatedAt', 'isDeleted',
        'deletedAt'
      ];
    }

    function isValidTransactionBase(data) {
      return data.keys().hasAll([
            'description', 'value_cents', 'schemaVersion', 'type',
            'category', 'date', 'source', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly(txAllowedKeys())
          && isStringSized(data.description, 2, 160)
          && isPositiveSafeInt(data.value_cents)
          && data.schemaVersion == 2
          && data.type in ['entrada', 'saida']
          && isStringSized(data.category, 1, 80)
          && isIsoDate(data.date)
          && data.source in ['csv', 'ofx', 'pdf', 'manual']
          && (!('tags' in data) || data.tags is list)
          && (!('isRecurring' in data) || data.isRecurring is bool)
          && (!('fitId' in data) || data.fitId == null || isStringSized(data.fitId, 1, 160))
          && (!('account' in data) || isStringSized(data.account, 1, 120))
          && (!('accountId' in data) || isStringSized(data.accountId, 1, 120))
          && (!('cardId' in data) || isStringSized(data.cardId, 1, 120))
          && (!('importHash' in data) || isStringSized(data.importHash, 64, 64))
          && (!('isDeleted' in data) || data.isDeleted is bool);
    }

    function isValidTransactionCreate() {
      let data = request.resource.data;
      return isValidTransactionBase(data)
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && !('deletedAt' in data)
          && !('uid' in data)
          && !('id' in data)
          && !('value' in data);
    }

    function isValidTransactionUpdate() {
      let data = request.resource.data;
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return isValidTransactionBase(data)
          && data.createdAt == resource.data.createdAt
          && data.updatedAt == request.time
          && !changed.hasAny(['createdAt', 'importHash'])
          && !('uid' in data)
          && !('id' in data)
          && !('value' in data)
          && (!changed.hasAny(['deletedAt']) || data.deletedAt == request.time);
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['name', 'type', 'balance', 'schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly(['name', 'type', 'balance', 'schemaVersion', 'createdAt', 'updatedAt'])
          && isStringSized(data.name, 2, 100)
          && data.type in ['corrente', 'poupanca', 'investimento', 'cartao', 'divida']
          && isSafeInt(data.balance)
          && data.schemaVersion == 2;
    }

    function isValidAccountCreate() {
      return isValidAccount(request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidAccountUpdate() {
      return isValidAccount(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
    }

    function isValidTransactionHistory(data) {
      return data.keys().hasAll(['action', 'txId', 'createdAt', 'schemaVersion'])
          && data.keys().hasOnly([
            'action', 'txId', 'before', 'after', 'changedFields', 'origin',
            'reason', 'correlationId', 'importHash', 'amount_cents', 'category',
            'createdAt', 'schemaVersion'
          ])
          && isStringSized(data.action, 2, 40)
          && isStringSized(data.txId, 1, 128)
          && data.createdAt == request.time
          && data.schemaVersion == 1
          && (!('amount_cents' in data) || isSafeInt(data.amount_cents));
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['action', 'entity', 'createdAt', 'schemaVersion'])
          && data.keys().hasOnly([
            'action', 'entity', 'txId', 'importHash', 'source',
            'amount_cents', 'amount_display', 'details', 'metadata',
            'createdAt', 'schemaVersion'
          ])
          && isStringSized(data.action, 2, 80)
          && isStringSized(data.entity, 2, 80)
          && data.createdAt == request.time
          && data.schemaVersion == 2
          && (!('amount_cents' in data) || isSafeInt(data.amount_cents));
    }

    function isValidSystemLog(data) {
      return data.keys().hasAll(['type', 'detail', 'createdAt'])
          && data.keys().hasOnly(['type', 'detail', 'createdAt'])
          && data.type in ['AI_CALL', 'ERROR', 'BATCH']
          && isStringSized(data.detail, 1, 500)
          && data.createdAt == request.time;
    }

    function isValidUsageCreate() {
      return request.resource.data.keys().hasOnly(['count', 'lastReset'])
          && request.resource.data.count is int
          && request.resource.data.count >= 0
          && request.resource.data.count <= 1
          && request.resource.data.lastReset == request.time;
    }

    function isValidUsageUpdate() {
      let c = request.resource.data.count;
      return request.resource.data.keys().hasOnly(['count', 'lastReset'])
          && c is int && c >= 0 && c <= 50
          && request.resource.data.lastReset is timestamp
          && (c == resource.data.count + 1 || c <= 1);
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['category', 'targetAmount', 'period', 'month', 'schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly(['category', 'targetAmount', 'period', 'month', 'schemaVersion', 'createdAt', 'updatedAt'])
          && isStringSized(data.category, 1, 80)
          && isPositiveSafeInt(data.targetAmount)
          && data.period == 'monthly'
          && data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$')
          && data.schemaVersion == 2;
    }

    function isValidBudgetCreate() {
      return isValidBudget(request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidBudgetUpdate() {
      return isValidBudget(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
    }

    function isValidCategoryRule(data) {
      return data.keys().hasAll(['keyword', 'category'])
          && data.keys().hasOnly(['keyword', 'category', 'createdAt', 'updatedAt'])
          && isStringSized(data.keyword, 1, 100)
          && isStringSized(data.category, 1, 80);
    }

    function categoryAllowedKeys() {
      return [
        'name', 'normalizedName', 'type', 'color', 'icon',
        'isDefault', 'isActive', 'createdAt', 'updatedAt'
      ];
    }

    function isValidUserCategoryBase(data) {
      return data.keys().hasAll([
            'name', 'normalizedName', 'type', 'color',
            'isDefault', 'isActive', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly(categoryAllowedKeys())
          && isStringSized(data.name, 1, 80)
          && isStringSized(data.normalizedName, 1, 80)
          && data.type in ['entrada', 'saida', 'ambos']
          && isStringSized(data.color, 1, 40)
          && (!('icon' in data) || isStringSized(data.icon, 1, 40))
          && data.isDefault is bool
          && data.isActive is bool;
    }

    function isValidUserCategoryCreate() {
      return isValidUserCategoryBase(request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidUserCategoryUpdate() {
      return isValidUserCategoryBase(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
    }

    function isValidCreditCard(data) {
      return data.keys().hasAll(['name', 'limit', 'closingDay', 'dueDay', 'active', 'schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly(['name', 'limit', 'closingDay', 'dueDay', 'color', 'active', 'schemaVersion', 'createdAt', 'updatedAt'])
          && isStringSized(data.name, 2, 100)
          && isPositiveSafeInt(data.limit)
          && data.closingDay is int && data.closingDay >= 1 && data.closingDay <= 31
          && data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 31
          && data.active is bool
          && data.schemaVersion == 2;
    }

    function isValidRecurringTask(data, userId) {
      return data.keys().hasAll([
            'description', 'category', 'dueDay', 'active',
            'frequency', 'schemaVersion', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly([
            'description', 'value', 'value_cents', 'type', 'category',
            'dueDay', 'active', 'frequency', 'schemaVersion',
            'createdAt', 'updatedAt', 'uid'
          ])
          && (('value' in data) || ('value_cents' in data))
          && isStringSized(data.description, 2, 160)
          && (!('value' in data) || isPositiveSafeInt(data.value))
          && (!('value_cents' in data) || isPositiveSafeInt(data.value_cents))
          && (!('type' in data) || data.type in ['entrada', 'saida', 'receita', 'despesa'])
          && isStringSized(data.category, 1, 80)
          && data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 31
          && data.active is bool
          && data.frequency in ['mensal', 'anual']
          && data.schemaVersion == 2
          && (!('uid' in data) || data.uid == userId);
    }

    function isValidRecurringTaskCreate(userId) {
      return isValidRecurringTask(request.resource.data, userId)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidRecurringTaskUpdate(userId) {
      return isValidRecurringTask(request.resource.data, userId)
          && request.resource.data.createdAt == resource.data.createdAt
          && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['updatedAt'])
              || request.resource.data.updatedAt == request.time);
    }

    function isValidBasisPoints(value, min, max) {
      return isSafeInt(value) && value >= min && value <= max;
    }

    function isValidSimulation(data, userId) {
      return data.keys().hasAll(['schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly([
            'name', 'description', 'scenario',
            'inflacao', 'corteDespesas', 'aumentoSalario',
            'inflacaoBps', 'corteDespesasBps', 'aumentoSalarialBps',
            'meses', 'iteracoes',
            'saldoInicialCents', 'receitaMensalCents', 'despesaFixaCents',
            'mediaVariavelCents', 'desvioVariavelCents',
            'probabilidadeSobrevivencia', 'p10Final', 'p50Final', 'p90Final',
            'chartData', 'schemaVersion', 'createdAt', 'updatedAt', 'uid'
          ])
          && (!('name' in data) || isStringSized(data.name, 1, 100))
          && (!('description' in data) || isStringSized(data.description, 1, 500))
          && (!('scenario' in data) || isStringSized(data.scenario, 1, 80))
          && (!('inflacao' in data) || isValidBasisPoints(data.inflacao, 0, 100))
          && (!('corteDespesas' in data) || isValidBasisPoints(data.corteDespesas, 0, 100))
          && (!('aumentoSalario' in data) || isValidBasisPoints(data.aumentoSalario, 0, 100))
          && (!('inflacaoBps' in data) || isValidBasisPoints(data.inflacaoBps, 0, 10000))
          && (!('corteDespesasBps' in data) || isValidBasisPoints(data.corteDespesasBps, 0, 10000))
          && (!('aumentoSalarialBps' in data) || isValidBasisPoints(data.aumentoSalarialBps, 0, 10000))
          && (!('meses' in data) || (data.meses is int && data.meses >= 1 && data.meses <= 600))
          && (!('iteracoes' in data) || (data.iteracoes is int && data.iteracoes >= 1 && data.iteracoes <= 100000))
          && (!('saldoInicialCents' in data) || isSafeInt(data.saldoInicialCents))
          && (!('receitaMensalCents' in data) || isPositiveSafeInt(data.receitaMensalCents))
          && (!('despesaFixaCents' in data) || isPositiveSafeInt(data.despesaFixaCents))
          && (!('mediaVariavelCents' in data) || isPositiveSafeInt(data.mediaVariavelCents))
          && (!('desvioVariavelCents' in data) || isSafeInt(data.desvioVariavelCents))
          && (!('probabilidadeSobrevivencia' in data) || isValidBasisPoints(data.probabilidadeSobrevivencia, 0, 100))
          && (!('p10Final' in data) || isSafeInt(data.p10Final))
          && (!('p50Final' in data) || isSafeInt(data.p50Final))
          && (!('p90Final' in data) || isSafeInt(data.p90Final))
          && (!('chartData' in data) || data.chartData is list)
          && data.schemaVersion == 2
          && (!('uid' in data) || data.uid == userId);
    }

    function isValidSimulationCreate(userId) {
      return isValidSimulation(request.resource.data, userId)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidSimulationUpdate(userId) {
      return isValidSimulation(request.resource.data, userId)
          && request.resource.data.createdAt == resource.data.createdAt
          && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['updatedAt'])
              || request.resource.data.updatedAt == request.time);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransactionCreate();
        allow update: if isOwner(userId) && isValidTransactionUpdate();
        allow delete: if false;

        match /history/{historyId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidTransactionHistory(request.resource.data);
          allow update, delete: if false;
        }
      }

      match /accounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAccountCreate();
        allow update: if isOwner(userId) && isValidAccountUpdate();
        allow delete: if isOwner(userId);
      }

      match /audit_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAuditLog(request.resource.data);
        allow update, delete: if false;
      }

      match /system_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSystemLog(request.resource.data);
        allow update, delete: if false;
      }

      match /usage/ai_calls {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUsageCreate();
        allow update: if isOwner(userId) && isValidUsageUpdate();
        allow delete: if false;
      }

      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBudgetCreate();
        allow update: if isOwner(userId) && isValidBudgetUpdate();
        allow delete: if isOwner(userId);
      }

      match /categoryRules/{ruleId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCategoryRule(request.resource.data);
        allow update: if isOwner(userId) && isValidCategoryRule(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /categories/{categoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserCategoryCreate();
        allow update: if isOwner(userId) && isValidUserCategoryUpdate();
        allow delete: if false;
      }

      match /creditCards/{cardId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCreditCard(request.resource.data);
        allow update: if isOwner(userId) && isValidCreditCard(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
        allow delete: if isOwner(userId);
      }

      match /recurringTasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRecurringTaskCreate(userId);
        allow update: if isOwner(userId) && isValidRecurringTaskUpdate(userId);
        allow delete: if isOwner(userId);
      }

      match /recurring/{taskId} {
        allow read, write: if false;
      }

      match /simulations/{simId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSimulationCreate(userId);
        allow update: if isOwner(userId) && isValidSimulationUpdate(userId);
        allow delete: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
