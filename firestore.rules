rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSafeInt(value) {
      return value is int
          && value >= -9007199254740991
          && value <= 9007199254740991;
    }

    function isPositiveSafeInt(value) {
      return isSafeInt(value) && value > 0;
    }

    function isIsoDate(value) {
      return value is string && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isYearMonth(value) {
      return value is string && value.matches('^[0-9]{4}-[0-9]{2}$');
    }

    function isStringSized(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isSafeCorrelationId(value) {
      return isStringSized(value, 16, 80)
          && value.matches('^[A-Za-z0-9_-]+$');
    }

    function isValidHistoryAction(value) {
      return value in [
        'CREATE',
        'UPDATE',
        'SOFT_DELETE',
        'RESTORE',
        'BULK_UPDATE',
        'UNDO_BULK_UPDATE',
        'IMPORT'
      ];
    }

    function isValidHistoryOrigin(value) {
      return value in [
        'manual',
        'import',
        'reconcile',
        'bulk',
        'system',
        'recurring',
        'ai'
      ];
    }

    function isValidHistoryChangedFields(value) {
      return value is list
          && value.size() <= 32
          && value.hasOnly([
            'description', 'value_cents', 'schemaVersion', 'type', 'category',
            'date', 'source', 'account', 'accountId', 'cardId', 'fitId',
            'tags', 'isRecurring', 'createdAt', 'updatedAt', 'isDeleted',
            'deletedAt', 'reconciliationStatus', 'reconciliationSource',
            'reconciledAt', 'reconciledBy',
            'installmentGroupId', 'installmentIndex', 'installmentCount', 'installmentTotalCents',
            'descriptionLower', 'paidInvoiceMonth'
          ]);
    }

    function isValidHistorySnapshot(value) {
      return value is map
          && !value.keys().hasAny([
            'id', 'uid', 'value', 'importHash', '_lastOpId', 'correlationId'
          ]);
    }

    function isValidAuditAction(value) {
      return value in [
        'IMPORT_TRANSACTION',
        'BULK_UPDATE',
        'UNDO_BULK_UPDATE',
        'ADD_RECURRING',
        'UPDATE_RECURRING',
        'DELETE_RECURRING'
      ];
    }

    function isValidAuditEntity(value) {
      return value in [
        'TRANSACTION',
        'RECURRING_TASK'
      ];
    }

    function isValidAuditSource(value) {
      return value in [
        'manual',
        'import',
        'csv',
        'ofx',
        'pdf',
        'bulk',
        'system'
      ];
    }

    function txAllowedKeys() {
      return [
        'description', 'value_cents', 'schemaVersion', 'type', 'category',
        'date', 'source', 'account', 'accountId', 'cardId', 'fitId', 'tags',
        'isRecurring', 'importHash', 'createdAt', 'updatedAt', 'isDeleted',
        'deletedAt', 'reconciliationStatus', 'reconciliationSource',
        'reconciledAt', 'reconciledBy', '_lastOpId',
        'fromAccountId', 'toAccountId',
        'installmentGroupId', 'installmentIndex', 'installmentCount', 'installmentTotalCents',
        'descriptionLower', 'paidInvoiceMonth'
      ];
    }

    function txPath(userId, txId) {
      return /databases/$(database)/documents/users/$(userId)/transactions/$(txId);
    }

    function txHistoryCreatePath(userId, txId) {
      return /databases/$(database)/documents/users/$(userId)/transactions/$(txId)/history/create;
    }

    function txHistoryPath(userId, txId, historyId) {
      return /databases/$(database)/documents/users/$(userId)/transactions/$(txId)/history/$(historyId);
    }

    function accountPath(userId, accountId) {
      return /databases/$(database)/documents/users/$(userId)/accounts/$(accountId);
    }

    function accountHistoryCreatePath(userId, accountId) {
      return /databases/$(database)/documents/users/$(userId)/accounts/$(accountId)/history/create;
    }

    function accountHistoryDeletePath(userId, accountId) {
      return /databases/$(database)/documents/users/$(userId)/accounts/$(accountId)/history/delete;
    }

    function accountHistoryPath(userId, accountId, historyId) {
      return /databases/$(database)/documents/users/$(userId)/accounts/$(accountId)/history/$(historyId);
    }

    function recurringTaskPath(userId, taskId) {
      return /databases/$(database)/documents/users/$(userId)/recurringTasks/$(taskId);
    }

    function recurringTaskHistoryCreatePath(userId, taskId) {
      return /databases/$(database)/documents/users/$(userId)/recurringTasks/$(taskId)/history/create;
    }

    function recurringTaskHistoryDeletePath(userId, taskId) {
      return /databases/$(database)/documents/users/$(userId)/recurringTasks/$(taskId)/history/delete;
    }

    function recurringTaskHistoryPath(userId, taskId, historyId) {
      return /databases/$(database)/documents/users/$(userId)/recurringTasks/$(taskId)/history/$(historyId);
    }

    function isValidTransactionBase(data) {
      return data.keys().hasAll([
            'description', 'value_cents', 'schemaVersion', 'type',
            'category', 'date', 'source', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly(txAllowedKeys())
          && isStringSized(data.description, 2, 160)
          && isPositiveSafeInt(data.value_cents)
          && data.schemaVersion == 2
          && data.type in ['entrada', 'saida', 'transferencia']
          && isStringSized(data.category, 1, 80)
          && isIsoDate(data.date)
          && data.source in ['csv', 'ofx', 'pdf', 'manual']
          && (!('tags' in data) || data.tags is list)
          && (!('isRecurring' in data) || data.isRecurring is bool)
          && (!('fitId' in data) || data.fitId == null || isStringSized(data.fitId, 1, 160))
          && (!('account' in data) || isStringSized(data.account, 1, 120))
          && (!('accountId' in data) || isStringSized(data.accountId, 1, 120))
          && (!('cardId' in data) || isStringSized(data.cardId, 1, 120))
          && (!('importHash' in data) || isStringSized(data.importHash, 64, 64))
          && (!('isDeleted' in data) || data.isDeleted is bool)
          && (!('reconciliationStatus' in data) || data.reconciliationStatus == 'reconciled')
          && (!('reconciliationSource' in data) || data.reconciliationSource == 'import')
          && (!('reconciledAt' in data) || data.reconciledAt is timestamp)
          && (!('reconciledBy' in data) || isStringSized(data.reconciledBy, 1, 128))
          && (!('paidInvoiceMonth' in data) || (
            isYearMonth(data.paidInvoiceMonth)
            && data.type == 'saida'
            && ('cardId' in data)
          ));
    }

    function isValidTransactionCreateBase(userId) {
      let data = request.resource.data;
      return isValidTransactionBase(data)
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && !('deletedAt' in data)
          && !('uid' in data)
          && !('id' in data)
          && !('value' in data)
          && (!('reconciledAt' in data) || data.reconciledAt == request.time)
          && (!('reconciledBy' in data) || data.reconciledBy == userId);
    }

    function isValidImportTransactionCreate(userId, txId) {
      let data = request.resource.data;
      let historyPath = txHistoryCreatePath(userId, txId);
      return isValidTransactionCreateBase(userId)
          && data.source != 'manual'
          && ('importHash' in data)
          && data.importHash == txId
          && !data.keys().hasAny([
            'isDeleted', 'deletedAt',
            'reconciliationStatus', 'reconciliationSource',
            'reconciledAt', 'reconciledBy', '_lastOpId'
          ])
          && !exists(historyPath)
          && existsAfter(historyPath);
    }

    function isValidManualTransactionCreate(userId, txId) {
      let data = request.resource.data;
      let historyPath = txHistoryCreatePath(userId, txId);
      return isValidTransactionCreateBase(userId)
          && data.source == 'manual'
          && !data.keys().hasAny([
            'importHash', 'isDeleted', 'deletedAt',
            'reconciliationStatus', 'reconciliationSource',
            'reconciledAt', 'reconciledBy'
          ])
          && !exists(historyPath)
          && existsAfter(historyPath);
    }

    function isValidTransactionCreate(userId, txId) {
      return isValidImportTransactionCreate(userId, txId)
          || isValidManualTransactionCreate(userId, txId);
    }

    function isValidTransactionUpdate(userId) {
      let data = request.resource.data;
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return isValidTransactionBase(data)
          && data.createdAt == resource.data.createdAt
          && data.updatedAt == request.time
          && !changed.hasAny(['createdAt', 'importHash'])
          && !('uid' in data)
          && !('id' in data)
          && !('value' in data)
          && (!changed.hasAny(['deletedAt']) || data.deletedAt == request.time)
          && (!changed.hasAny(['reconciledAt']) || data.reconciledAt == request.time)
          && (!changed.hasAny(['reconciledBy']) || data.reconciledBy == userId);
    }

    // Modelo A (8B-5): valida history pareado no mesmo commit. _lastOpId obrigatório.
    // getAfter() chamado uma única vez (variável h) para evitar o limite de 1000 expressões.
    // Aceita a matriz completa de (action, origin) usada pelos helpers WithHistory em produção.
    // isStringSized rejeita null, número, objeto, lista, string vazia e string acima de 128 chars.
    function isValidUpdateHistoryPairedInSameBatch(userId, txId) {
      let opId = request.resource.data._lastOpId;
      let historyPath = txHistoryPath(userId, txId, opId);
      let h = getAfter(historyPath).data;
      return isStringSized(opId, 1, 128)
          && !exists(historyPath)
          && existsAfter(historyPath)
          && h.txId == txId
          && (
            (h.action == 'UPDATE'           && h.origin in ['manual', 'ai', 'reconcile']) ||
            (h.action == 'SOFT_DELETE'      && h.origin == 'manual')                      ||
            (h.action == 'BULK_UPDATE'      && h.origin == 'bulk')                        ||
            (h.action == 'UNDO_BULK_UPDATE' && h.origin == 'bulk')
          )
          && (
            !('correlationId' in h)
            || h.action in ['BULK_UPDATE', 'UNDO_BULK_UPDATE']
            || h.correlationId == opId
          );
    }

    // Modelo A (8B-5): _lastOpId + history pareado obrigatórios em todo UPDATE de transaction.
    function isValidTransactionUpdateWithHistory(userId, txId) {
      return isValidTransactionUpdate(userId)
          && isValidUpdateHistoryPairedInSameBatch(userId, txId);
    }

    function accountAllowedKeys() {
      return [
        'name', 'type', 'balance', 'schemaVersion', 'createdAt', 'updatedAt',
        '_lastOpId'
      ];
    }

    function accountSnapshotKeys() {
      return [
        'name', 'type', 'balance', 'schemaVersion', 'createdAt', 'updatedAt'
      ];
    }

    function accountChangedFieldKeys() {
      return ['name', 'type', 'balance', 'schemaVersion'];
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['name', 'type', 'balance', 'schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly(accountAllowedKeys())
          && isStringSized(data.name, 2, 100)
          && data.type in ['corrente', 'poupanca', 'investimento', 'cartao', 'divida']
          && isSafeInt(data.balance)
          && data.schemaVersion == 2
          && (!('_lastOpId' in data) || isSafeCorrelationId(data._lastOpId));
    }

    function isValidAccountCreate(userId, accountId) {
      let historyPath = accountHistoryCreatePath(userId, accountId);
      return isValidAccount(request.resource.data)
          && !('_lastOpId' in request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
          && !exists(historyPath)
          && existsAfter(historyPath);
    }

    function isValidAccountUpdate(userId, accountId) {
      let opId = request.resource.data._lastOpId;
      let historyPath = accountHistoryPath(userId, accountId, opId);
      let h = getAfter(historyPath).data;
      return isValidAccount(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time
          && isSafeCorrelationId(opId)
          && !exists(historyPath)
          && existsAfter(historyPath)
          && h.action == 'UPDATE'
          && h.origin == 'manual'
          && h.accountId == accountId
          && h.correlationId == opId;
    }

    function isValidAccountDelete(userId, accountId) {
      let historyPath = accountHistoryDeletePath(userId, accountId);
      let h = getAfter(historyPath).data;
      return !exists(historyPath)
          && existsAfter(historyPath)
          && h.action == 'DELETE'
          && h.origin == 'manual'
          && h.accountId == accountId
          && isSafeCorrelationId(h.correlationId);
    }

    function isValidAccountHistoryAction(value) {
      return value in ['CREATE', 'UPDATE', 'DELETE'];
    }

    function isValidAccountHistoryChangedFields(value) {
      return value is list
          && value.size() <= 4
          && value.hasOnly(accountChangedFieldKeys());
    }

    function isValidAccountHistorySnapshot(value) {
      return value is map
          && value.keys().hasOnly(accountSnapshotKeys())
          && (!('name' in value) || isStringSized(value.name, 2, 100))
          && (!('type' in value) || value.type in ['corrente', 'poupanca', 'investimento', 'cartao', 'divida'])
          && (!('balance' in value) || isSafeInt(value.balance))
          && (!('schemaVersion' in value) || value.schemaVersion == 2);
    }

    function isValidAccountHistory(data, accountId) {
      return data.keys().hasAll(['action', 'accountId', 'createdAt', 'schemaVersion', 'origin', 'correlationId'])
          && data.keys().hasOnly([
            'action', 'accountId', 'before', 'after', 'changedFields',
            'origin', 'correlationId', 'createdAt', 'schemaVersion'
          ])
          && isValidAccountHistoryAction(data.action)
          && isStringSized(data.accountId, 1, 128)
          && data.accountId == accountId
          && data.createdAt == request.time
          && data.schemaVersion == 1
          && data.origin == 'manual'
          && isSafeCorrelationId(data.correlationId)
          && (!('before' in data) || isValidAccountHistorySnapshot(data.before))
          && (!('after' in data) || isValidAccountHistorySnapshot(data.after))
          && (!('changedFields' in data) || isValidAccountHistoryChangedFields(data.changedFields));
    }

    function accountSnapshotMatches(account, snapshot) {
      return optionalHistoryFieldMatches(account, snapshot, 'name')
          && optionalHistoryFieldMatches(account, snapshot, 'type')
          && optionalHistoryFieldMatches(account, snapshot, 'balance')
          && optionalHistoryFieldMatches(account, snapshot, 'schemaVersion')
          && optionalHistoryFieldMatches(account, snapshot, 'createdAt')
          && optionalHistoryFieldMatches(account, snapshot, 'updatedAt');
    }

    function isValidAccountCreateHistoryInSameBatch(data, userId, accountId, historyId) {
      let accountRef = accountPath(userId, accountId);
      let account = getAfter(accountRef).data;
      return historyId == 'create'
          && data.action == 'CREATE'
          && !exists(accountRef)
          && existsAfter(accountRef)
          && !('before' in data)
          && ('after' in data)
          && data.after.keys().hasAll(accountSnapshotKeys())
          && !('_lastOpId' in account)
          && accountSnapshotMatches(account, data.after);
    }

    function isValidAccountUpdateHistoryInSameBatch(data, userId, accountId, historyId) {
      let accountRef = accountPath(userId, accountId);
      let before = get(accountRef).data;
      let after = getAfter(accountRef).data;
      return historyId == data.correlationId
          && data.action == 'UPDATE'
          && exists(accountRef)
          && existsAfter(accountRef)
          && after._lastOpId == data.correlationId
          && ('before' in data)
          && ('after' in data)
          && accountSnapshotMatches(before, data.before)
          && accountSnapshotMatches(after, data.after);
    }

    function isValidAccountDeleteHistoryInSameBatch(data, userId, accountId, historyId) {
      let accountRef = accountPath(userId, accountId);
      let before = get(accountRef).data;
      return historyId == 'delete'
          && data.action == 'DELETE'
          && exists(accountRef)
          && !existsAfter(accountRef)
          && ('before' in data)
          && !('after' in data)
          && accountSnapshotMatches(before, data.before);
    }

    function isValidTransactionHistory(data, txId) {
      return data.keys().hasAll(['action', 'txId', 'createdAt', 'schemaVersion'])
          && data.keys().hasOnly([
            'action', 'txId', 'before', 'after', 'changedFields', 'origin',
            'reason', 'correlationId', 'importHash', 'amount_cents', 'category',
            'createdAt', 'schemaVersion'
          ])
          && isValidHistoryAction(data.action)
          && isStringSized(data.txId, 1, 128)
          && data.txId == txId
          && data.createdAt == request.time
          && data.schemaVersion == 1
          && (!('before' in data) || isValidHistorySnapshot(data.before))
          && (!('after' in data) || isValidHistorySnapshot(data.after))
          && (!('changedFields' in data) || isValidHistoryChangedFields(data.changedFields))
          && (!('origin' in data) || isValidHistoryOrigin(data.origin))
          && (!('reason' in data) || isStringSized(data.reason, 1, 240))
          && (!('correlationId' in data) || isSafeCorrelationId(data.correlationId))
          && (!('importHash' in data) || isStringSized(data.importHash, 64, 64))
          && (!('amount_cents' in data) || isSafeInt(data.amount_cents))
          && (!('category' in data) || isStringSized(data.category, 1, 80));
    }

    function isManualCreateHistory(data) {
      return data.action == 'CREATE'
          && ('origin' in data)
          && data.origin == 'manual';
    }

    function isImportCreateHistory(data) {
      return data.action == 'CREATE'
          && ('origin' in data)
          && data.origin == 'import';
    }

    function optionalHistoryFieldMatches(tx, after, field) {
      return (!(field in tx) && !(field in after))
          || ((field in tx) && (field in after) && tx[field] == after[field]);
    }

    function isValidImportCreateHistoryForTransaction(data, txId, tx) {
      return tx.source in ['csv', 'ofx', 'pdf']
          && ('importHash' in tx)
          && tx.importHash == txId
          && !tx.keys().hasAny([
            'uid', 'id', 'value', 'isDeleted', 'deletedAt',
            'reconciliationStatus', 'reconciliationSource',
            'reconciledAt', 'reconciledBy', '_lastOpId'
          ])
          && isImportCreateHistory(data)
          && !('before' in data)
          && !('importHash' in data)
          && ('correlationId' in data)
          && ('amount_cents' in data)
          && data.amount_cents == tx.value_cents
          && ('category' in data)
          && data.category == tx.category
          && ('after' in data)
          && data.after.keys().hasOnly([
            'description', 'value_cents', 'schemaVersion', 'type', 'category',
            'date', 'source', 'account', 'accountId', 'cardId', 'fitId',
            'tags', 'isRecurring', 'descriptionLower'
          ])
          && data.after.description == tx.description
          && data.after.value_cents == tx.value_cents
          && data.after.schemaVersion == 2
          && data.after.type == tx.type
          && data.after.category == tx.category
          && data.after.date == tx.date
          && data.after.source == tx.source
          && optionalHistoryFieldMatches(tx, data.after, 'account')
          && optionalHistoryFieldMatches(tx, data.after, 'accountId')
          && optionalHistoryFieldMatches(tx, data.after, 'cardId')
          && optionalHistoryFieldMatches(tx, data.after, 'fitId')
          && optionalHistoryFieldMatches(tx, data.after, 'tags')
          && optionalHistoryFieldMatches(tx, data.after, 'isRecurring')
          && ('changedFields' in data)
          && data.changedFields.hasAll([
            'description', 'value_cents', 'schemaVersion', 'type',
            'category', 'date', 'source'
          ]);
    }

    function isValidManualCreateHistoryForTransaction(data, tx) {
      return tx.source == 'manual'
          && !tx.keys().hasAny([
            'importHash', 'uid', 'id', 'value', 'isDeleted', 'deletedAt',
            'reconciliationStatus', 'reconciliationSource',
            'reconciledAt', 'reconciledBy'
          ])
          && isManualCreateHistory(data)
          && ('amount_cents' in data)
          && data.amount_cents == tx.value_cents
          && ('category' in data)
          && data.category == tx.category
          && ('after' in data)
          && data.after.keys().hasOnly([
            'description', 'value_cents', 'schemaVersion', 'type', 'category',
            'date', 'source', 'account', 'accountId', 'cardId', 'fitId',
            'tags', 'isRecurring', 'descriptionLower',
            'installmentGroupId', 'installmentIndex', 'installmentCount', 'installmentTotalCents',
            'paidInvoiceMonth'
          ])
          && data.after.description == tx.description
          && data.after.value_cents == tx.value_cents
          && data.after.schemaVersion == 2
          && data.after.type == tx.type
          && data.after.category == tx.category
          && data.after.date == tx.date
          && data.after.source == 'manual'
          && ('isRecurring' in tx)
          && ('isRecurring' in data.after)
          && data.after.isRecurring == tx.isRecurring
          && optionalHistoryFieldMatches(tx, data.after, 'account')
          && optionalHistoryFieldMatches(tx, data.after, 'accountId')
          && optionalHistoryFieldMatches(tx, data.after, 'cardId')
          && optionalHistoryFieldMatches(tx, data.after, 'fitId')
          && optionalHistoryFieldMatches(tx, data.after, 'tags')
          && optionalHistoryFieldMatches(tx, data.after, 'paidInvoiceMonth')
          && ('changedFields' in data)
          && data.changedFields.hasAll([
            'description', 'value_cents', 'schemaVersion', 'type',
            'category', 'date', 'source', 'isRecurring'
          ]);
    }

    function isValidManualCreateHistoryInSameBatch(data, userId, txId, historyId) {
      let transactionPath = txPath(userId, txId);
      return historyId == 'create'
          && isManualCreateHistory(data)
          && !exists(transactionPath)
          && existsAfter(transactionPath)
          && isValidManualCreateHistoryForTransaction(data, getAfter(transactionPath).data);
    }

    function isValidImportCreateHistoryInSameBatch(data, userId, txId, historyId) {
      let transactionPath = txPath(userId, txId);
      return historyId == 'create'
          && isImportCreateHistory(data)
          && !exists(transactionPath)
          && existsAfter(transactionPath)
          && isValidImportCreateHistoryForTransaction(data, txId, getAfter(transactionPath).data);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['action', 'entity', 'createdAt', 'schemaVersion'])
          && data.keys().hasOnly([
            'action', 'entity', 'txId', 'source',
            'amount_cents', 'amount_display', 'details', 'metadata',
            'createdAt', 'schemaVersion'
          ])
          && isValidAuditAction(data.action)
          && isValidAuditEntity(data.entity)
          && data.createdAt == request.time
          && data.schemaVersion == 2
          && (!('txId' in data) || isStringSized(data.txId, 1, 128))
          && (!('source' in data) || isValidAuditSource(data.source))
          && (!('amount_cents' in data) || isSafeInt(data.amount_cents))
          && (!('amount_display' in data) || data.amount_display is number)
          && (!('details' in data) || isStringSized(data.details, 1, 500))
          && (!('metadata' in data) || data.metadata is map);
    }

    function isValidSystemLog(data) {
      return data.keys().hasAll(['type', 'detail', 'createdAt'])
          && data.keys().hasOnly(['type', 'detail', 'createdAt'])
          && data.type in ['AI_CALL', 'ERROR', 'BATCH']
          && isStringSized(data.detail, 1, 500)
          && data.createdAt == request.time;
    }

    function isValidUsageCreate() {
      return request.resource.data.keys().hasOnly(['count', 'lastReset'])
          && request.resource.data.count is int
          && request.resource.data.count >= 0
          && request.resource.data.count <= 1
          && request.resource.data.lastReset == request.time;
    }

    function isValidUsageUpdate() {
      let c = request.resource.data.count;
      return request.resource.data.keys().hasOnly(['count', 'lastReset'])
          && c is int && c >= 0 && c <= 50
          && request.resource.data.lastReset is timestamp
          && (c == resource.data.count + 1 || c <= 1);
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['category', 'targetAmount', 'period', 'month', 'schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly(['category', 'targetAmount', 'period', 'month', 'schemaVersion', 'createdAt', 'updatedAt'])
          && isStringSized(data.category, 1, 80)
          && isPositiveSafeInt(data.targetAmount)
          && data.period == 'monthly'
          && data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$')
          && data.schemaVersion == 2;
    }

    function isValidBudgetCreate() {
      return isValidBudget(request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidBudgetUpdate() {
      return isValidBudget(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
    }

    function isValidCategoryRule(data) {
      return data.keys().hasAll(['keyword', 'category'])
          && data.keys().hasOnly(['keyword', 'category', 'createdAt', 'updatedAt'])
          && isStringSized(data.keyword, 1, 100)
          && isStringSized(data.category, 1, 80);
    }

    function categoryAllowedKeys() {
      return [
        'name', 'normalizedName', 'type', 'color', 'icon',
        'isDefault', 'isActive', 'createdAt', 'updatedAt'
      ];
    }

    function isValidUserCategoryBase(data) {
      return data.keys().hasAll([
            'name', 'normalizedName', 'type', 'color',
            'isDefault', 'isActive', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly(categoryAllowedKeys())
          && isStringSized(data.name, 1, 80)
          && isStringSized(data.normalizedName, 1, 80)
          && data.type in ['entrada', 'saida', 'ambos']
          && isStringSized(data.color, 1, 40)
          && (!('icon' in data) || isStringSized(data.icon, 1, 40))
          && data.isDefault is bool
          && data.isActive is bool;
    }

    function isValidUserCategoryCreate() {
      return isValidUserCategoryBase(request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidUserCategoryUpdate() {
      return isValidUserCategoryBase(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
    }

    function isValidCreditCard(data) {
      return data.keys().hasAll(['name', 'limit', 'closingDay', 'dueDay', 'active', 'schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly(['name', 'limit', 'closingDay', 'dueDay', 'color', 'active', 'schemaVersion', 'createdAt', 'updatedAt'])
          && isStringSized(data.name, 2, 100)
          && isPositiveSafeInt(data.limit)
          && data.closingDay is int && data.closingDay >= 1 && data.closingDay <= 31
          && data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 31
          && data.active is bool
          && data.schemaVersion == 2;
    }

    function isValidRecurringTask(data, userId) {
      return data.keys().hasAll([
            'description', 'category', 'dueDay', 'active',
            'frequency', 'schemaVersion', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly([
            'description', 'value', 'value_cents', 'type', 'category',
            'dueDay', 'active', 'frequency', 'schemaVersion',
            'createdAt', 'updatedAt', 'uid', '_lastOpId',
            'dueMonth', 'lastExecutedMonth'
          ])
          && (('value' in data) || ('value_cents' in data))
          && isStringSized(data.description, 2, 160)
          && (!('value' in data) || isPositiveSafeInt(data.value))
          && (!('value_cents' in data) || isPositiveSafeInt(data.value_cents))
          && (!('type' in data) || data.type in ['entrada', 'saida', 'receita', 'despesa'])
          && isStringSized(data.category, 1, 80)
          && data.dueDay is int && data.dueDay >= 1 && data.dueDay <= 31
          && data.active is bool
          && data.frequency in ['mensal', 'anual']
          && data.schemaVersion == 2
          && (!('uid' in data) || data.uid == userId)
          && (!('_lastOpId' in data) || isSafeCorrelationId(data._lastOpId));
    }

    function isValidRecurringTaskCreate(userId, taskId) {
      let historyPath = recurringTaskHistoryCreatePath(userId, taskId);
      return isValidRecurringTask(request.resource.data, userId)
          && !('_lastOpId' in request.resource.data)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
          && !exists(historyPath)
          && existsAfter(historyPath);
    }

    function isValidRecurringTaskUpdate(userId, taskId) {
      let opId = request.resource.data._lastOpId;
      let historyPath = recurringTaskHistoryPath(userId, taskId, opId);
      let h = getAfter(historyPath).data;
      return isValidRecurringTask(request.resource.data, userId)
          && request.resource.data.createdAt == resource.data.createdAt
          && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['updatedAt'])
              || request.resource.data.updatedAt == request.time)
          && isSafeCorrelationId(opId)
          && !exists(historyPath)
          && existsAfter(historyPath)
          && h.action == 'UPDATE'
          && h.origin == 'manual'
          && h.recurringTaskId == taskId
          && h.correlationId == opId;
    }

    function isValidRecurringTaskDelete(userId, taskId) {
      let historyPath = recurringTaskHistoryDeletePath(userId, taskId);
      let h = getAfter(historyPath).data;
      return !exists(historyPath)
          && existsAfter(historyPath)
          && h.action == 'DELETE'
          && h.origin == 'manual'
          && h.recurringTaskId == taskId
          && isSafeCorrelationId(h.correlationId);
    }

    function recurringTaskSnapshotKeys() {
      return [
        'description', 'value_cents', 'type', 'category', 'dueDay', 'active',
        'frequency', 'schemaVersion', 'createdAt', 'updatedAt',
        'dueMonth', 'lastExecutedMonth'
      ];
    }

    function recurringTaskChangedFieldKeys() {
      return [
        'description', 'value_cents', 'type', 'category', 'dueDay', 'active',
        'frequency', 'schemaVersion', 'dueMonth', 'lastExecutedMonth'
      ];
    }

    function isValidRecurringTaskHistoryAction(value) {
      return value in ['CREATE', 'UPDATE', 'DELETE'];
    }

    function isValidRecurringTaskHistoryChangedFields(value) {
      return value is list
          && value.size() <= 8
          && value.hasOnly(recurringTaskChangedFieldKeys());
    }

    function isValidRecurringTaskHistorySnapshot(value) {
      return value is map
          && value.keys().hasOnly(recurringTaskSnapshotKeys())
          && (!('description' in value) || isStringSized(value.description, 2, 160))
          && (!('value_cents' in value) || isPositiveSafeInt(value.value_cents))
          && (!('type' in value) || value.type in ['entrada', 'saida', 'receita', 'despesa'])
          && (!('category' in value) || isStringSized(value.category, 1, 80))
          && (!('dueDay' in value) || (value.dueDay is int && value.dueDay >= 1 && value.dueDay <= 31))
          && (!('active' in value) || value.active is bool)
          && (!('frequency' in value) || value.frequency in ['mensal', 'anual'])
          && (!('schemaVersion' in value) || value.schemaVersion == 2);
    }

    function isValidRecurringTaskHistory(data, taskId) {
      return data.keys().hasAll(['action', 'recurringTaskId', 'createdAt', 'schemaVersion', 'origin', 'correlationId'])
          && data.keys().hasOnly([
            'action', 'recurringTaskId', 'before', 'after', 'changedFields',
            'origin', 'correlationId', 'createdAt', 'schemaVersion'
          ])
          && isValidRecurringTaskHistoryAction(data.action)
          && isStringSized(data.recurringTaskId, 1, 128)
          && data.recurringTaskId == taskId
          && data.createdAt == request.time
          && data.schemaVersion == 1
          && data.origin == 'manual'
          && isSafeCorrelationId(data.correlationId)
          && (!('before' in data) || isValidRecurringTaskHistorySnapshot(data.before))
          && (!('after' in data) || isValidRecurringTaskHistorySnapshot(data.after))
          && (!('changedFields' in data) || isValidRecurringTaskHistoryChangedFields(data.changedFields));
    }

    function isValidRecurringTaskCreateHistoryInSameBatch(data, userId, taskId, historyId) {
      return historyId == 'create'
          && data.action == 'CREATE'
          && !exists(recurringTaskPath(userId, taskId))
          && existsAfter(recurringTaskPath(userId, taskId))
          && !('before' in data)
          && ('after' in data)
          && data.after.keys().hasAll([
            'description', 'value_cents', 'category', 'dueDay', 'active',
            'frequency', 'schemaVersion', 'createdAt', 'updatedAt'
          ]);
    }

    function isValidRecurringTaskUpdateHistoryInSameBatch(data, userId, taskId, historyId) {
      return historyId == data.correlationId
          && data.action == 'UPDATE'
          && exists(recurringTaskPath(userId, taskId))
          && existsAfter(recurringTaskPath(userId, taskId))
          && getAfter(recurringTaskPath(userId, taskId)).data._lastOpId == data.correlationId
          && ('before' in data)
          && ('after' in data);
    }

    function isValidRecurringTaskDeleteHistoryInSameBatch(data, userId, taskId, historyId) {
      return historyId == 'delete'
          && data.action == 'DELETE'
          && exists(recurringTaskPath(userId, taskId))
          && !existsAfter(recurringTaskPath(userId, taskId))
          && ('before' in data)
          && !('after' in data);
    }

    function isValidBasisPoints(value, min, max) {
      return isSafeInt(value) && value >= min && value <= max;
    }

    function isValidSimulation(data, userId) {
      return data.keys().hasAll(['schemaVersion', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly([
            'name', 'description', 'scenario',
            'inflacao', 'corteDespesas', 'aumentoSalario',
            'inflacaoBps', 'corteDespesasBps', 'aumentoSalarialBps',
            'meses', 'iteracoes',
            'saldoInicialCents', 'receitaMensalCents', 'despesaFixaCents',
            'mediaVariavelCents', 'desvioVariavelCents',
            'probabilidadeSobrevivencia', 'p10Final', 'p50Final', 'p90Final',
            'chartData', 'schemaVersion', 'createdAt', 'updatedAt', 'uid'
          ])
          && (!('name' in data) || isStringSized(data.name, 1, 100))
          && (!('description' in data) || isStringSized(data.description, 1, 500))
          && (!('scenario' in data) || isStringSized(data.scenario, 1, 80))
          && (!('inflacao' in data) || isValidBasisPoints(data.inflacao, 0, 100))
          && (!('corteDespesas' in data) || isValidBasisPoints(data.corteDespesas, 0, 100))
          && (!('aumentoSalario' in data) || isValidBasisPoints(data.aumentoSalario, 0, 100))
          && (!('inflacaoBps' in data) || isValidBasisPoints(data.inflacaoBps, 0, 10000))
          && (!('corteDespesasBps' in data) || isValidBasisPoints(data.corteDespesasBps, 0, 10000))
          && (!('aumentoSalarialBps' in data) || isValidBasisPoints(data.aumentoSalarialBps, 0, 10000))
          && (!('meses' in data) || (data.meses is int && data.meses >= 1 && data.meses <= 600))
          && (!('iteracoes' in data) || (data.iteracoes is int && data.iteracoes >= 1 && data.iteracoes <= 100000))
          && (!('saldoInicialCents' in data) || isSafeInt(data.saldoInicialCents))
          && (!('receitaMensalCents' in data) || isPositiveSafeInt(data.receitaMensalCents))
          && (!('despesaFixaCents' in data) || isPositiveSafeInt(data.despesaFixaCents))
          && (!('mediaVariavelCents' in data) || isPositiveSafeInt(data.mediaVariavelCents))
          && (!('desvioVariavelCents' in data) || isSafeInt(data.desvioVariavelCents))
          && (!('probabilidadeSobrevivencia' in data) || isValidBasisPoints(data.probabilidadeSobrevivencia, 0, 100))
          && (!('p10Final' in data) || isSafeInt(data.p10Final))
          && (!('p50Final' in data) || isSafeInt(data.p50Final))
          && (!('p90Final' in data) || isSafeInt(data.p90Final))
          && (!('chartData' in data) || data.chartData is list)
          && data.schemaVersion == 2
          && (!('uid' in data) || data.uid == userId);
    }

    function isValidSimulationCreate(userId) {
      return isValidSimulation(request.resource.data, userId)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
    }

    function isValidSimulationUpdate(userId) {
      return isValidSimulation(request.resource.data, userId)
          && request.resource.data.createdAt == resource.data.createdAt
          && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['updatedAt'])
              || request.resource.data.updatedAt == request.time);
    }

    function isValidShoppingUnit(unit) {
      return unit in ['un', 'kg', 'g', 'L', 'mL', 'cx', 'pct', 'dz'];
    }

    function isValidShoppingListCreate(data) {
      return data.keys().hasAll(['uid', 'name', 'estimatedTotalCents', 'status', 'items', 'createdAt', 'updatedAt', 'schemaVersion'])
          && data.uid is string
          && isStringSized(data.name, 1, 80)
          && isSafeInt(data.estimatedTotalCents) && data.estimatedTotalCents >= 0
          && data.status in ['open', 'in_progress', 'done']
          && data.items is list && data.items.size() <= 200
          && data.schemaVersion == 1
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }

    function isValidPriceObservationCreate(data) {
      return data.keys().hasAll(['uid', 'productName', 'store', 'unitPriceCents', 'quantity', 'unit', 'observedAt', 'createdAt', 'schemaVersion'])
          && data.uid is string
          && isStringSized(data.productName, 1, 120)
          && isStringSized(data.store, 1, 80)
          && isPositiveSafeInt(data.unitPriceCents)
          && data.quantity is string && data.quantity.size() >= 1
          && isValidShoppingUnit(data.unit)
          && data.observedAt is string && data.observedAt.size() == 10
          && data.schemaVersion == 1
          && data.createdAt == request.time;
    }

    function isValidDebt(data) {
      return data.keys().hasAll([
            'uid', 'name', 'creditor', 'totalCents', 'remainingCents',
            'interestRate', 'installments', 'paidInstallments',
            'dueDayOfMonth', 'startDate', 'category', 'active',
            'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly([
            'uid', 'name', 'creditor', 'totalCents', 'remainingCents',
            'interestRate', 'installments', 'paidInstallments',
            'dueDayOfMonth', 'startDate', 'category', 'active',
            'createdAt', 'updatedAt'
          ])
          && isStringSized(data.name, 1, 200)
          && isStringSized(data.creditor, 1, 200)
          && isPositiveSafeInt(data.totalCents)
          && isPositiveSafeInt(data.remainingCents)
          && data.interestRate is number
          && data.interestRate >= 0
          && isSafeInt(data.installments)
          && data.installments >= 1
          && isSafeInt(data.paidInstallments)
          && data.paidInstallments >= 0
          && isSafeInt(data.dueDayOfMonth)
          && data.dueDayOfMonth >= 1
          && data.dueDayOfMonth <= 31
          && isStringSized(data.startDate, 10, 10)
          && data.category in ['emprestimo', 'financiamento', 'cartao', 'cheque_especial', 'outro']
          && data.active is bool;
    }

    function isValidDebtCreate(data) {
      return isValidDebt(data)
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }

    function isValidDebtUpdate(data) {
      return data.keys().hasAll([
            'uid', 'name', 'creditor', 'totalCents', 'remainingCents',
            'interestRate', 'installments', 'paidInstallments',
            'dueDayOfMonth', 'startDate', 'category', 'active',
            'createdAt', 'updatedAt'
          ])
          && isStringSized(data.name, 1, 200)
          && isStringSized(data.creditor, 1, 200)
          && isPositiveSafeInt(data.totalCents)
          && data.remainingCents is int
          && data.remainingCents >= 0
          && data.interestRate is number
          && data.interestRate >= 0
          && isSafeInt(data.installments)
          && data.installments >= 1
          && isSafeInt(data.paidInstallments)
          && data.paidInstallments >= 0
          && isSafeInt(data.dueDayOfMonth)
          && data.dueDayOfMonth >= 1
          && data.dueDayOfMonth <= 31
          && isStringSized(data.startDate, 10, 10)
          && data.category in ['emprestimo', 'financiamento', 'cartao', 'cheque_especial', 'outro']
          && data.active is bool
          && data.createdAt == resource.data.createdAt;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['name', 'targetCents', 'currentCents', 'createdAt', 'updatedAt'])
          && data.keys().hasOnly([
            'name', 'targetCents', 'currentCents', 'deadline', 'emoji', 'createdAt', 'updatedAt'
          ])
          && isStringSized(data.name, 1, 160)
          && isPositiveSafeInt(data.targetCents)
          && isSafeInt(data.currentCents)
          && (!('deadline' in data) || data.deadline == null || isStringSized(data.deadline, 10, 10))
          && (!('emoji' in data) || isStringSized(data.emoji, 1, 8));
    }

    function isValidGoalCreate() {
      let data = request.resource.data;
      return isValidGoal(data)
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }

    function isValidGoalUpdate() {
      let data = request.resource.data;
      return isValidGoal(data)
          && data.createdAt == resource.data.createdAt
          && data.updatedAt == request.time;
    }

    function isValidScoreHistoryWrite(monthId) {
      let data = request.resource.data;
      // monthId must be YYYY-MM format
      return monthId.matches('^[0-9]{4}-[0-9]{2}$')
          && data.keys().hasAll(['score', 'schemaVersion'])
          && data.score is number
          && data.score >= 0 && data.score <= 100
          && data.schemaVersion == 1
          && !data.keys().hasAny(['uid', 'id', 'importHash']);
    }

    function isValidChallengeWrite() {
      let data = request.resource.data;
      return data.keys().hasAll(['category', 'targetPct', 'baselineCents', 'deadlineDays',
                                  'startDate', 'endDate', 'xp', 'status', 'schemaVersion'])
          && data.keys().hasOnly(['category', 'targetPct', 'baselineCents', 'deadlineDays',
                                   'startDate', 'endDate', 'xp', 'status', 'schemaVersion', 'createdAt'])
          && data.category is string && data.category.size() > 0
          && data.targetPct is number && data.targetPct >= 1 && data.targetPct <= 100
          && data.baselineCents is int && data.baselineCents >= 0
          && data.deadlineDays is int && data.deadlineDays >= 1
          && data.startDate is string
          && data.endDate is string
          && data.xp is int && data.xp >= 0
          && data.status in ['active', 'won', 'lost']
          && data.schemaVersion == 1
          && !data.keys().hasAny(['uid', 'id', 'importHash']);
    }

    function isValidChallengeUpdate() {
      let data = request.resource.data;
      return data.keys().hasOnly(['category', 'targetPct', 'baselineCents', 'deadlineDays',
                                   'startDate', 'endDate', 'xp', 'status', 'schemaVersion', 'createdAt'])
          && data.xp is int && data.xp >= 0
          && data.status in ['active', 'won', 'lost']
          && data.schemaVersion == 1
          && data.category == resource.data.category
          && !data.keys().hasAny(['uid', 'id', 'importHash']);
    }


    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransactionCreate(userId, txId);
        allow update: if isOwner(userId) && isValidTransactionUpdateWithHistory(userId, txId);
        allow delete: if false;

        match /history/{historyId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidTransactionHistory(request.resource.data, txId)
            && (
              isValidManualCreateHistoryInSameBatch(request.resource.data, userId, txId, historyId)
              || isValidImportCreateHistoryInSameBatch(request.resource.data, userId, txId, historyId)
              || (
                request.resource.data.action != 'CREATE'
                && exists(txPath(userId, txId))
              )
            );
          allow update, delete: if false;
        }
      }

      match /accounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAccountCreate(userId, accountId);
        allow update: if isOwner(userId) && isValidAccountUpdate(userId, accountId);
        allow delete: if isOwner(userId) && isValidAccountDelete(userId, accountId);

        match /history/{historyId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidAccountHistory(request.resource.data, accountId)
            && (
              isValidAccountCreateHistoryInSameBatch(request.resource.data, userId, accountId, historyId)
              || isValidAccountUpdateHistoryInSameBatch(request.resource.data, userId, accountId, historyId)
              || isValidAccountDeleteHistoryInSameBatch(request.resource.data, userId, accountId, historyId)
            );
          allow update, delete: if false;
        }
      }

      match /audit_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAuditLog(request.resource.data);
        allow update, delete: if false;
      }

      match /system_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSystemLog(request.resource.data);
        allow update, delete: if false;
      }

      match /usage/ai_calls {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUsageCreate();
        allow update: if isOwner(userId) && isValidUsageUpdate();
        allow delete: if false;
      }

      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBudgetCreate();
        allow update: if isOwner(userId) && isValidBudgetUpdate();
        allow delete: if isOwner(userId);
      }

      match /categoryRules/{ruleId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCategoryRule(request.resource.data);
        allow update: if isOwner(userId) && isValidCategoryRule(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /categories/{categoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserCategoryCreate();
        allow update: if isOwner(userId) && isValidUserCategoryUpdate();
        allow delete: if false;
      }

      match /creditCards/{cardId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCreditCard(request.resource.data);
        allow update: if isOwner(userId) && isValidCreditCard(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;
        allow delete: if isOwner(userId);
      }

      match /recurringTasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRecurringTaskCreate(userId, taskId);
        allow update: if isOwner(userId) && isValidRecurringTaskUpdate(userId, taskId);
        allow delete: if isOwner(userId) && isValidRecurringTaskDelete(userId, taskId);

        match /history/{historyId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidRecurringTaskHistory(request.resource.data, taskId)
            && (
              isValidRecurringTaskCreateHistoryInSameBatch(request.resource.data, userId, taskId, historyId)
              || isValidRecurringTaskUpdateHistoryInSameBatch(request.resource.data, userId, taskId, historyId)
              || isValidRecurringTaskDeleteHistoryInSameBatch(request.resource.data, userId, taskId, historyId)
            );
          allow update, delete: if false;
        }
      }

      match /recurring/{taskId} {
        allow read, write: if false;
      }

      match /simulations/{simId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSimulationCreate(userId);
        allow update: if isOwner(userId) && isValidSimulationUpdate(userId);
        allow delete: if isOwner(userId);
      }

      match /debts/{debtId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidDebtCreate(request.resource.data);
        allow update: if isOwner(userId) && isValidDebtUpdate(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Idempotency keys — escrito exclusivamente pelo Admin SDK (server-side).
      // Clients nunca lêem nem escrevem nesta coleção.
      match /idempotency/{keyId} {
        allow read, write: if false;
      }

      // LGPD — consentimentos do usuário (leitura e escrita pelo próprio owner).
      match /consents/{consentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['type', 'granted', 'updatedAt'])
          && request.resource.data.keys().hasOnly(['type', 'granted', 'updatedAt'])
          && request.resource.data.type is string
          && request.resource.data.granted is bool
          && request.resource.data.updatedAt == request.time;
        allow update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['type', 'granted', 'updatedAt'])
          && request.resource.data.keys().hasOnly(['type', 'granted', 'updatedAt'])
          && request.resource.data.type == resource.data.type
          && request.resource.data.granted is bool
          && request.resource.data.updatedAt == request.time;
        allow delete: if false;
      }

      // LGPD — log de processamento de dados (leitura pelo owner; escrita exclusiva pelo servidor).
      match /dataProcessingLog/{logId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /goals/{goalId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoalCreate();
        allow update: if isOwner(userId) && isValidGoalUpdate();
        allow delete: if isOwner(userId);
      }

      // Score history — persisted monthly by client; read-only after write.
      // Document ID is YYYY-MM; schema is versioned.
      match /scoreHistory/{monthId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidScoreHistoryWrite(monthId);
        allow update: if isOwner(userId) && isValidScoreHistoryWrite(monthId);
        allow delete: if false;
      }

      match /challenges/{challengeId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidChallengeWrite();
        allow update: if isOwner(userId) && isValidChallengeUpdate();
        allow delete: if isOwner(userId);
      }

      // Compras Inteligentes — listas de compras com itens embutidos.
      match /shoppingLists/{listId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidShoppingListCreate(request.resource.data);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Histórico de preços por produto/loja — append-mostly, sem delete.
      match /priceObservations/{obsId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidPriceObservationCreate(request.resource.data);
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // FCM tokens — gravados pelo client (owner); lidos apenas pelo Admin SDK (server-side).
      match /fcmTokens/{tokenId} {
        allow read:   if false;
        allow create: if isOwner(userId)
            && request.resource.data.keys().hasAll(['token', 'platform', 'createdAt'])
            && request.resource.data.keys().hasOnly(['token', 'platform', 'createdAt'])
            && request.resource.data.token   == tokenId
            && request.resource.data.platform == 'web'
            && request.resource.data.createdAt == request.time;
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // Diário de decisões do Agente Financeiro (FASE H / H-0).
      // Auditoria append-mostly: owner cria; update restrito à transição de
      // status (userDecision/outcomeStatus); sem delete client-side (apenas
      // hard-delete LGPD via Admin SDK). Ver docs/AI_DECISION_JOURNAL.md.
      function isValidDecisionCreate() {
        let d = request.resource.data;
        return d.keys().hasAll(['userId', 'createdAt', 'intent', 'question', 'toolsUsed', 'userDecision', 'outcomeStatus'])
            && d.keys().hasOnly(['userId', 'createdAt', 'intent', 'question', 'snapshotRef', 'toolsUsed', 'simulationResult', 'proposedAction', 'userDecision', 'outcomeStatus'])
            && d.userId == userId
            && d.createdAt == request.time
            && d.intent in ['get_balances', 'get_invoice', 'explain_month', 'cashflow_briefing', 'simulate_purchase', 'plan_debt_payment', 'create_budget_proposal', 'contribute_to_goal_proposal']
            && d.question is string && d.question.size() <= 2000
            && d.toolsUsed is list
            && d.userDecision in ['confirmed', 'rejected', 'expired', 'none']
            && d.outcomeStatus in ['pending', 'applied', 'reverted', 'n/a']
            && (!('snapshotRef' in d) || d.snapshotRef is string)
            && (!('simulationResult' in d) || d.simulationResult is map)
            && (!('proposedAction' in d) || d.proposedAction is map);
      }

      function isValidDecisionUpdate() {
        let d = request.resource.data;
        let prev = resource.data;
        // Imutáveis: identidade e contexto original da decisão.
        return d.userId == prev.userId
            && d.createdAt == prev.createdAt
            && d.intent == prev.intent
            && d.question == prev.question
            && d.keys().hasOnly(['userId', 'createdAt', 'intent', 'question', 'snapshotRef', 'toolsUsed', 'simulationResult', 'proposedAction', 'userDecision', 'outcomeStatus'])
            // Apenas a transição de status pode evoluir.
            && d.userDecision in ['confirmed', 'rejected', 'expired', 'none']
            && d.outcomeStatus in ['pending', 'applied', 'reverted', 'n/a'];
      }

      match /decisions/{decisionId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidDecisionCreate();
        allow update: if isOwner(userId) && isValidDecisionUpdate();
        allow delete: if false;
      }
    }

    // ─── Finanças Compartilhadas ─────────────────────────────────────────────
    match /groups/{groupId} {
      function isMember() {
        return request.auth != null
            && request.auth.uid in resource.data.memberUids;
      }

      function isMemberAfter() {
        return request.auth != null
            && request.auth.uid in request.resource.data.memberUids;
      }

      function isGroupOwner() {
        return request.auth != null
            && resource.data.ownerUid == request.auth.uid;
      }

      function isValidGroupCreate() {
        let d = request.resource.data;
        return d.keys().hasAll(['name', 'ownerUid', 'memberUids', 'members', 'createdAt', 'updatedAt', 'schemaVersion'])
            && d.ownerUid == request.auth.uid
            && d.name is string && d.name.size() >= 1 && d.name.size() <= 80
            && d.memberUids is list && d.memberUids.size() >= 1
            && request.auth.uid in d.memberUids
            && d.members is list
            && d.schemaVersion == 1
            && d.createdAt == request.time
            && d.updatedAt == request.time;
      }

      allow read:   if isMember();
      allow create: if request.auth != null && isValidGroupCreate();
      allow update: if isGroupOwner() && isMemberAfter();
      allow delete: if isGroupOwner();

      match /expenses/{expenseId} {
        function isGroupMemberForExpense() {
          return request.auth != null
              && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
        }

        function isValidExpenseCreate() {
          let d = request.resource.data;
          return d.keys().hasAll([
                'description', 'totalCents', 'category', 'date',
                'payerUid', 'payerDisplayName', 'splitMethod', 'shares',
                'groupId', 'createdAt', 'updatedAt', 'schemaVersion'
              ])
              && d.description is string && d.description.size() >= 1 && d.description.size() <= 160
              && isPositiveSafeInt(d.totalCents)
              && d.splitMethod in ['igual', 'proporcional', 'personalizado']
              && d.shares is list && d.shares.size() >= 1
              && d.groupId == groupId
              && d.schemaVersion == 1
              && d.createdAt == request.time
              && d.updatedAt == request.time;
        }

        allow read:   if isGroupMemberForExpense();
        allow create: if isGroupMemberForExpense() && isValidExpenseCreate();
        allow update: if isGroupMemberForExpense();
        allow delete: if isGroupMemberForExpense();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
