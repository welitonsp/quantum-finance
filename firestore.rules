rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // count must be int in [0, 50]; allow increment by 1 OR reset to ≤1
    function isValidUsageWrite() {
      let c = request.resource.data.count;
      return c is int && c >= 0 && c <= 50
          && (c == resource.data.count + 1 || c <= 1);
    }

    function isValidSystemLog() {
      let d = request.resource.data;
      return d.keys().hasAll(['type', 'detail', 'createdAt'])
          && d.type in ['AI_CALL', 'ERROR', 'BATCH'];
    }

    // Validação de balance em REAIS (número, pode ser negativo para cartão/dívida)
    function isValidBalance(v) {
      return v is number && v >= -10000000 && v <= 10000000;
    }

    function isValidAccount() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'type', 'balance'])
          && d.name is string && d.name.size() > 0 && d.name.size() <= 100
          && d.type in ['corrente', 'poupanca', 'investimento', 'cartao', 'divida']
          && isValidBalance(d.balance);
    }

    function isValidCategoryRule() {
      let d = request.resource.data;
      return d.keys().hasAll(['keyword', 'category'])
          && d.keyword is string && d.keyword.size() > 0 && d.keyword.size() <= 100
          && d.category is string && d.category.size() > 0 && d.category.size() <= 50;
    }

    function isValidBudget() {
      let d = request.resource.data;
      return d.keys().hasAll(['category', 'targetAmount', 'month'])
          && d.category is string && d.category.size() > 0 && d.category.size() <= 50
          && d.targetAmount is number && d.targetAmount > 0 && d.targetAmount <= 10000000
          && d.month is string && d.month.matches('^[0-9]{4}-[0-9]{2}$');
    }

    function isValidSimulation() {
      let d = request.resource.data;
      return d.keys().hasAll(['createdAt'])
          && d.createdAt is number;
    }

    // ─── User namespace ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /transactions/{txId} {
        allow read, write: if isOwner(userId);
      }

      // Audit logs — immutable after creation
      match /audit_logs/{logId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /recurringTasks/{taskId} {
        allow read, write: if isOwner(userId);
      }

      // AI usage tracker — count validated to prevent abuse
      match /usage/ai_calls {
        allow read: if isOwner(userId);
        // First write: count must start at 0 or 1
        allow create: if isOwner(userId)
            && request.resource.data.count is int
            && request.resource.data.count <= 1;
        // Subsequent writes: increment by 1 OR daily reset to ≤1
        allow update: if isOwner(userId) && isValidUsageWrite();
        allow delete: if false;
      }

      // System logs — append-only, schema-validated
      match /system_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSystemLog();
        allow update, delete: if false;
      }

      match /accounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAccount();
        allow update: if isOwner(userId) && isValidAccount();
        allow delete: if isOwner(userId);
      }

      match /categoryRules/{ruleId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCategoryRule();
        allow update: if isOwner(userId) && isValidCategoryRule();
        allow delete: if isOwner(userId);
      }

      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBudget();
        allow update: if isOwner(userId) && isValidBudget();
        allow delete: if isOwner(userId);
      }

      match /simulations/{simId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSimulation();
        allow update: if isOwner(userId) && isValidSimulation();
        allow delete: if isOwner(userId);
      }
    }

    // ─── Deny everything else by default ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
