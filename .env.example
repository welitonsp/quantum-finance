# Firebase Web SDK (public client identifiers; no Admin SDK secrets here)
VITE_FIREBASE_API_KEY="replace-with-firebase-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:0000000000000000000000"

# AI providers are server-only.
# Configure Gemini with:
# firebase functions:secrets:set GEMINI_API_KEY

# Firebase App Check - reCAPTCHA v3
# VITE_RECAPTCHA_SITE_KEY é pública e necessária para emitir tokens App Check no bundle.
VITE_RECAPTCHA_SITE_KEY=
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN é SENSÍVEL; use só em DEV/preview controlado.
# Nunca coloque token real neste arquivo.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=
# VITE_USE_EMULATOR=true pula App Check e conecta o Functions Emulator local.
VITE_USE_EMULATOR=

# Sentry — monitoramento de erros em produção
# Só ativo quando VITE_SENTRY_DSN está definido E mode === 'production'
VITE_SENTRY_DSN=
# Vars de CI/build para upload de source maps (segredos — não commitar)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=quantum-finance
