{
  "name": "quantum-finance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run --pool=threads --maxWorkers=1",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage --pool=threads --maxWorkers=1",
    "deploy": "npm run build && firebase deploy --only hosting",
    "test:rules": "firebase emulators:exec --only firestore --project demo-quantum-finance \"vitest run src/__tests__/firestoreRules.audit.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e-report",
    "bundlecheck": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.4",
    "decimal.js": "^10.6.0",
    "firebase": "^10.8.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.7",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "form-data": "3.0.5",
    "@firebase/auth": {
      "undici": "6.27.0"
    },
    "@firebase/auth-compat": {
      "undici": "6.27.0"
    },
    "@firebase/firestore": {
      "undici": "6.27.0"
    },
    "@firebase/functions": {
      "undici": "6.27.0"
    },
    "@firebase/storage": {
      "undici": "6.27.0"
    },
    "jsdom": {
      "undici": "7.28.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.2",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  }
}
