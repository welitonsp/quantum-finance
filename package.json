{
  "name": "quantum-finance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run --pool=threads --maxWorkers=1",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage --pool=threads --maxWorkers=1",
    "deploy": "npm run build && firebase deploy --only hosting",
    "test:rules": "firebase emulators:exec --only firestore --project demo-quantum-finance \"vitest run src/__tests__/firestoreRules.audit.test.ts\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.24",
    "chart.js": "^4.5.1",
    "decimal.js": "^10.6.0",
    "firebase": "^10.8.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.563.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.2"
  }
}
